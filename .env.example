# =============================================================================
# Environment Variables for Mental Health Safety Sandbox / Hackathon
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The .env file is loaded by training scripts and by guardrail submissions
# (e.g. example_submission_llm_judge.py). NEVER commit .env to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# OpenAI (optional)
# -----------------------------------------------------------------------------
# Used by example submissions and LLM judge guardrails.
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# Cohere - LLM provider (optional)
# -----------------------------------------------------------------------------
# Used by the Cohere provider and example_submission_llm_judge (alternative to OpenAI).
# Get your API key from: https://dashboard.cohere.com/api-keys
COHERE_BASE_URL=https://api.cohere.com
COHERE_API_KEY=your-cohere-api-key-here

# -----------------------------------------------------------------------------
# Hugging Face - model downloads (optional)
# -----------------------------------------------------------------------------
# Required for gated models (e.g. Llama). Get token: https://huggingface.co/settings/tokens
HF_TOKEN=your-huggingface-token-here
HUGGINGFACE_HUB_TOKEN=your-huggingface-token-here
